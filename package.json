{
  "name": "bpsr-build-planner",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "build:web": "tsc -b && vite build --config vite.config.web.ts",
    "preview:web": "vite preview --config vite.config.web.ts",
    "tauri": "tauri",
    "extract:ztable": "node scripts/extract-ztable.mjs",
    "release": "node scripts/release.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.1",
    "i18next": "24.2.3",
    "lz-string": "1.5.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-i18next": "15.7.4",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.3",
    "@types/node": "22.20.0",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "6.0.2",
    "prettier": "3.9.4",
    "typescript": "5.9.3",
    "vite": "8.0.16",
    "vitest": "4.1.10"
  }
}
