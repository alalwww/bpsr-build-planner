{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BPSR Build Planner",
  "version": "0.6.1",
  "identifier": "dev.bpsr-build-planner.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "BPSR Build Planner",
        "url": "index.html",
        "width": 1440,
        "height": 1080,
        "minWidth": 1000,
        "minHeight": 800,
        "visible": true
      },
      {
        "label": "settings",
        "title": "Settings",
        "url": "settings.html",
        "width": 480,
        "height": 360,
        "resizable": false,
        "visible": false
      },
      {
        "label": "about",
        "title": "About BPSR Build Planner",
        "url": "about.html",
        "parent": "main",
        "center": true,
        "width": 520,
        "height": 640,
        "minWidth": 400,
        "minHeight": 400,
        "visible": false
      },
      {
        "label": "stats-detail",
        "title": "Stats Detail",
        "url": "stats-detail.html",
        "width": 540,
        "height": 540,
        "minWidth": 360,
        "minHeight": 300,
        "visible": false
      },
      {
        "label": "ability-score",
        "title": "Ability Score",
        "url": "ability-score.html",
        "width": 480,
        "height": 560,
        "minWidth": 360,
        "minHeight": 300,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVDODU4OTM2RUExREZFQQpSV1RxMzZGdWsxaklEZ2s2akh0ZTVkWDlJQWZTUGNuUjFhQnBhRmNoazVGWFBUWHpLNzlndDJUSwo=",
      "endpoints": [
        "https://github.com/alalwww/bpsr-build-planner/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
