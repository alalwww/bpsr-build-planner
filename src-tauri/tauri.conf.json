{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BPSR Build Planner",
  "version": "0.3.1",
  "identifier": "dev.bpsr-build-planner.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "BPSR Build Planner",
        "url": "index.html",
        "width": 1440,
        "height": 1080,
        "minWidth": 1000,
        "minHeight": 800,
        "visible": true
      },
      {
        "label": "settings",
        "title": "Settings",
        "url": "settings.html",
        "width": 480,
        "height": 360,
        "resizable": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
